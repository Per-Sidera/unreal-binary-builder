<Application x:Class="UnrealBinaryBuilder.App"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:hc="https://handyorg.github.io/handycontrol"
			 xmlns:local="clr-namespace:UnrealBinaryBuilder"
			 xmlns:conv="clr-namespace:UnrealBinaryBuilder.Converters"
			 StartupUri="Views/MainWindow.xaml">
	<Application.Resources>
		<ResourceDictionary>
			<ResourceDictionary.MergedDictionaries>
				<ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDark.xaml"/>
				<ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
			</ResourceDictionary.MergedDictionaries>

			<conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
			<conv:InverseBoolConverter x:Key="InverseBool"/>
			<conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
			<conv:HexToBrushConverter x:Key="HexToBrush"/>

			<!--
			  Deep-grey palette overrides.
			  Neutral charcoal background, slightly lifted panels, soft grey borders,
			  warm off-white text, and a teal-ish accent that doesn't fight the grey.
			-->
			<Color x:Key="PrimaryColor">#3DBEB0</Color>
			<Color x:Key="DarkPrimaryColor">#2EA095</Color>
			<Color x:Key="DarkPrimary2Color">#249088</Color>
			<Color x:Key="LightPrimaryColor">#4FD0C2</Color>
			<Color x:Key="AccentColor">#3DBEB0</Color>

			<Color x:Key="BackgroundColor">#1B1C1F</Color>
			<Color x:Key="RegionColor">#222327</Color>
			<Color x:Key="SecondaryRegionColor">#2A2B30</Color>
			<Color x:Key="ThirdlyRegionColor">#33343A</Color>
			<Color x:Key="BorderColor">#3A3B41</Color>
			<Color x:Key="SecondaryBorderColor">#2F3035</Color>

			<Color x:Key="PrimaryTextColor">#ECECEC</Color>
			<Color x:Key="SecondaryTextColor">#B5B6BB</Color>
			<Color x:Key="ThirdlyTextColor">#7E7F84</Color>
			<Color x:Key="ReverseTextColor">#1B1C1F</Color>

			<Color x:Key="DefaultColor">#2A2B30</Color>
			<Color x:Key="DarkDefaultColor">#33343A</Color>

			<SolidColorBrush x:Key="PrimaryBrush"           Color="{StaticResource PrimaryColor}"/>
			<SolidColorBrush x:Key="DarkPrimaryBrush"       Color="{StaticResource DarkPrimaryColor}"/>
			<SolidColorBrush x:Key="DarkPrimary2Brush"      Color="{StaticResource DarkPrimary2Color}"/>
			<SolidColorBrush x:Key="LightPrimaryBrush"      Color="{StaticResource LightPrimaryColor}"/>
			<SolidColorBrush x:Key="AccentBrush"            Color="{StaticResource AccentColor}"/>

			<SolidColorBrush x:Key="BackgroundBrush"        Color="{StaticResource BackgroundColor}"/>
			<SolidColorBrush x:Key="MainContentBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
			<SolidColorBrush x:Key="RegionBrush"            Color="{StaticResource RegionColor}"/>
			<SolidColorBrush x:Key="SecondaryRegionBrush"   Color="{StaticResource SecondaryRegionColor}"/>
			<SolidColorBrush x:Key="ThirdlyRegionBrush"     Color="{StaticResource ThirdlyRegionColor}"/>
			<SolidColorBrush x:Key="BorderBrush"            Color="{StaticResource BorderColor}"/>
			<SolidColorBrush x:Key="SecondaryBorderBrush"   Color="{StaticResource SecondaryBorderColor}"/>

			<SolidColorBrush x:Key="PrimaryTextBrush"       Color="{StaticResource PrimaryTextColor}"/>
			<SolidColorBrush x:Key="SecondaryTextBrush"     Color="{StaticResource SecondaryTextColor}"/>
			<SolidColorBrush x:Key="ThirdlyTextBrush"       Color="{StaticResource ThirdlyTextColor}"/>
			<SolidColorBrush x:Key="ReverseTextBrush"       Color="{StaticResource ReverseTextColor}"/>
			<SolidColorBrush x:Key="TextIconBrush"          Color="{StaticResource PrimaryTextColor}"/>

			<SolidColorBrush x:Key="DefaultBrush"           Color="{StaticResource DefaultColor}"/>
			<SolidColorBrush x:Key="DarkDefaultBrush"       Color="{StaticResource DarkDefaultColor}"/>
			<SolidColorBrush x:Key="DarkOpacityBrush"       Color="#000000" Opacity="0.55"/>
			<SolidColorBrush x:Key="TitleBrush"             Color="{StaticResource RegionColor}"/>

			<Style TargetType="GroupBox" BasedOn="{StaticResource GroupBoxOriginal}"/>
		</ResourceDictionary>
	</Application.Resources>
</Application>
