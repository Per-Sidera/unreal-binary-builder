<UserControl x:Class="UnrealBinaryBuilder.Views.LogPanel"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="clr-namespace:UnrealBinaryBuilder.ViewModels"
			 mc:Ignorable="d"
			 d:DataContext="{d:DesignInstance Type=vm:LogViewModel}"
			 d:DesignHeight="500" d:DesignWidth="1000">
	<Grid Background="#FF1A1A1B">
		<ScrollViewer x:Name="LogScroll" ScrollChanged="OnScrollChanged" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="12">
			<ItemsControl ItemsSource="{Binding Entries}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<StackPanel Orientation="Horizontal">
							<TextBlock FontFamily="Consolas" FontSize="12" Foreground="DimGray"
									   Text="{Binding Timestamp, StringFormat='[HH:mm:ss] ', Mode=OneWay}"/>
							<TextBlock FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap"
									   Foreground="{Binding Color}" Text="{Binding Message, Mode=OneWay}"/>
						</StackPanel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</Grid>
</UserControl>
