<hc:GlowWindow x:Class="UnrealBinaryBuilder.Views.MainWindow"
			   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			   xmlns:hc="https://handyorg.github.io/handycontrol"
			   xmlns:vm="clr-namespace:UnrealBinaryBuilder.ViewModels"
			   xmlns:views="clr-namespace:UnrealBinaryBuilder.Views"
			   mc:Ignorable="d"
			   Title="Unreal Binary Builder"
			   Background="{DynamicResource RegionBrush}"
			   ActiveGlowColor="{DynamicResource PrimaryColor}"
			   InactiveGlowColor="{DynamicResource SecondaryBorderColor}"
			   Width="1320" Height="820" MinWidth="1100" MinHeight="640"
			   WindowStartupLocation="CenterScreen"
			   Closing="OnClosing">
	<hc:GlowWindow.NonClientAreaContent>
		<StackPanel Orientation="Horizontal" VerticalAlignment="Stretch" Margin="8,0,8,0">
			<Menu Background="Transparent" VerticalAlignment="Stretch">
				<MenuItem Header="Preferences  ▾" Padding="12,4" VerticalAlignment="Stretch"
						  ToolTip="Open the user settings file (notepad) or the Appearance editor.">
					<MenuItem Header="Settings"
							  Command="{Binding OpenSettingsFileCommand}"
							  ToolTip="Open the saved Settings.json file for hand-editing."/>
					<MenuItem Header="Appearance…"
							  Command="{Binding OpenAppearanceCommand}"
							  ToolTip="Open the colour-palette editor (live preview, save/load, presets)."/>
				</MenuItem>
			</Menu>
			<Button Content="Changelog" Style="{StaticResource ButtonBaseStyle}" Command="{Binding OpenChangelogCommand}"
					ToolTip="Open the CHANGELOG. Falls back to the GitHub copy if no local file is shipped."/>
			<Button Content="About" Style="{StaticResource ButtonBaseStyle}" Click="OnAboutClicked"/>
			<TextBlock Text="{Binding VersionLabel}" Margin="12,0,0,0" VerticalAlignment="Center" Opacity="0.6"/>
		</StackPanel>
	</hc:GlowWindow.NonClientAreaContent>

	<DockPanel LastChildFill="True">

		<!-- Status bar -->
		<Border DockPanel.Dock="Bottom" Background="{DynamicResource RegionBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
			<Grid Margin="12,6">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Text="{Binding Status.Status}" Margin="0,0,16,0"/>
				<TextBlock Grid.Column="1" Text="{Binding Status.Step}" Margin="0,0,16,0"/>
				<TextBlock Grid.Column="2">
					<Run Text="Compiled: "/>
					<Run Text="{Binding Status.FilesCompiled, Mode=OneWay}"/>
					<Run Text=" • "/>
					<Run Text="Errors: "/>
					<Run Text="{Binding Log.ErrorCount, Mode=OneWay}" Foreground="Tomato"/>
					<Run Text=" • "/>
					<Run Text="Warnings: "/>
					<Run Text="{Binding Log.WarningCount, Mode=OneWay}" Foreground="Goldenrod"/>
				</TextBlock>
				<TextBlock Grid.Column="3" Text="{Binding Status.ElapsedDisplay}" Margin="16,0" HorizontalAlignment="Center" Opacity="0.7"/>
				<Button Grid.Column="4" Content="{Binding UpdateButtonContent}" Command="{Binding CheckForUpdatesCommand}" Padding="12,2" FontSize="11" Margin="0,0,8,0"
						Visibility="{Binding IsUpdaterConfigured, Converter={StaticResource BoolToVisibility}}"/>
				<Button Grid.Column="5" Content="Import Preset…" Command="{Binding ImportSettingsCommand}" Padding="12,2" FontSize="11" Margin="0,0,8,0"
						ToolTip="Load a settings preset (.json) — overwrites all current options. See examples\ for ready-made presets and reference.settings.json for an annotated catalog of every field."/>
				<Button Grid.Column="6" Content="Open Logs" Command="{Binding OpenLogFolderCommand}" Padding="12,2" FontSize="11"/>
			</Grid>
		</Border>

		<!-- Main tabs -->
		<hc:TabControl IsAnimationEnabled="True" ShowCloseButton="False"
					   Background="Transparent"
					   BorderBrush="{DynamicResource BorderBrush}"
					   BorderThickness="0,1,0,0">
			<hc:TabItem Header="Engine" IsSelected="True">
				<views:EngineTab DataContext="{Binding Engine}"/>
			</hc:TabItem>
			<hc:TabItem Header="Plugins">
				<views:PluginsTab DataContext="{Binding Plugins}"/>
			</hc:TabItem>
			<hc:TabItem Header="Output">
				<views:LogPanel DataContext="{Binding Log}"/>
			</hc:TabItem>
		</hc:TabControl>
	</DockPanel>
</hc:GlowWindow>
