<UserControl x:Class="UnrealBinaryBuilder.Views.EngineTab"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:hc="https://handyorg.github.io/handycontrol"
			 xmlns:vm="clr-namespace:UnrealBinaryBuilder.ViewModels"
			 mc:Ignorable="d"
			 d:DataContext="{d:DesignInstance Type=vm:EngineTabViewModel}"
			 d:DesignWidth="1280" d:DesignHeight="640">
	<UserControl.Resources>
		<Style x:Key="SectionHelp" TargetType="TextBlock">
			<Setter Property="Opacity" Value="0.6"/>
			<Setter Property="FontSize" Value="11"/>
			<Setter Property="Margin" Value="0,0,0,10"/>
			<Setter Property="TextWrapping" Value="Wrap"/>
		</Style>
	</UserControl.Resources>
	<Grid Margin="16">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Engine root + version -->
		<Border Grid.Row="0" Background="{DynamicResource RegionBrush}" CornerRadius="6" Padding="16" Margin="0,0,0,12"
				BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<TextBlock Text="Unreal Engine root" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4" Grid.ColumnSpan="2"/>
				<TextBlock Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource SectionHelp}"
						   Text="Folder containing Setup.bat / GenerateProjectFiles.bat — the root of your Unreal Engine source checkout."/>

				<TextBox Grid.Row="2" Grid.Column="0" Text="{Binding Settings.EngineRootPath, UpdateSourceTrigger=PropertyChanged}"
						 hc:InfoElement.Placeholder="e.g. C:\UnrealEngine"
						 Style="{StaticResource TextBoxExtend}" Margin="0,0,8,0"
						 ToolTip="Type or paste the path. The version label below updates as soon as a valid path is detected."/>
				<Button Grid.Row="2" Grid.Column="1" Content="Browse" Command="{Binding BrowseEngineRootCommand}" Width="100"/>

				<StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,8,0,0">
					<TextBlock Foreground="{DynamicResource PrimaryBrush}" Text="Detected: " VerticalAlignment="Center"/>
					<TextBlock VerticalAlignment="Center">
						<Run Text="UE "/>
						<Run Text="{Binding DetectedVersion, FallbackValue='—', Mode=OneWay}"/>
					</TextBlock>
					<TextBlock Margin="16,0,0,0" Visibility="{Binding GitInfo, Converter={StaticResource NullToVisibility}}">
						<Run Text="commit "/>
						<Run Text="{Binding GitInfo.ShortSha, Mode=OneWay}"/>
						<Run Text=" on "/>
						<Run Text="{Binding GitInfo.Branch, Mode=OneWay}"/>
					</TextBlock>
				</StackPanel>
			</Grid>
		</Border>

		<!-- Settings -->
		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<!-- Left column -->
				<StackPanel Grid.Column="0" Margin="0,0,8,0">

					<GroupBox Header="Pipeline">
						<StackPanel Margin="6">
							<TextBlock Style="{StaticResource SectionHelp}"
									   Text="Each stage runs in order: Setup → GenerateProjectFiles → AutomationTool → BuildGraph. Uncheck stages you've already completed to skip ahead."/>
							<CheckBox Content="Run Setup.bat" IsChecked="{Binding Settings.RunSetup}" Margin="0,4"
									  ToolTip="Fetches the ~10–30 GB of binary dependencies from Epic's CDN. Required after a fresh git clone; safe to skip on re-runs."/>
							<CheckBox Content="Run GenerateProjectFiles.bat" IsChecked="{Binding Settings.RunGenerateProjectFiles}" Margin="0,4"
									  ToolTip="Regenerates the .sln / .csproj files used by AutomationTool. Skip if you haven't pulled new commits since the last build."/>
							<CheckBox Content="Build AutomationTool" IsChecked="{Binding Settings.RunBuildAutomationTool}" Margin="0,4"
									  ToolTip="Compiles AutomationTool (UE5) or AutomationToolLauncher (UE4) — the C# tool that drives the engine compile. Skip if you've built it already."/>
							<CheckBox Content="Continue to Engine BuildGraph" IsChecked="{Binding Settings.ContinueToEngineBuild}" Margin="0,4"
									  ToolTip="Runs 'BuildGraph -target=Make Installed Build Win64', the actual engine compile. Turn off if you only want the prep stages."/>
						</StackPanel>
					</GroupBox>

					<GroupBox Header="Setup.bat / Git dependencies" Margin="0,12,0,0">
						<StackPanel Margin="6">
							<TextBlock Style="{StaticResource SectionHelp}"
									   Text="Controls how Setup.bat fetches binary blobs. Per-platform exclusions live in the Target platforms section — they translate to --exclude=&lt;platform&gt; here."/>
							<CheckBox Content="Sync all platforms (--all)" IsChecked="{Binding Settings.GitDependencyAll}" Margin="0,2"
									  ToolTip="Equivalent to running 'Setup.bat --all'. Pulls every platform's binaries even if you've unchecked them elsewhere. Mostly useful for engineers maintaining the engine itself."/>
							<CheckBox Content="Enable cache" IsChecked="{Binding Settings.GitDependencyEnableCache}" Margin="0,2"
									  ToolTip="Tells Setup.bat to cache downloaded blobs locally so a second sync of the same engine version is instant. Disable only if disk space is tight."/>
							<Grid Margin="0,8,0,0">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<TextBlock Text="Threads" VerticalAlignment="Center" Margin="0,0,6,0"
										   ToolTip="Parallel HTTP downloads. 8 is a sane default; raise on fast pipes, lower if your connection chokes."/>
								<TextBox Grid.Column="1" Text="{Binding Settings.GitDependencyThreads}" Margin="0,0,12,0"
										 ToolTip="--threads=N passed to Setup.bat. 4–16 is typical."/>
								<TextBlock Grid.Column="2" Text="Retries" VerticalAlignment="Center" Margin="0,0,6,0"
										   ToolTip="How many times Setup.bat retries a failed file before giving up."/>
								<TextBox Grid.Column="3" Text="{Binding Settings.GitDependencyMaxRetries}"
										 ToolTip="--max-retries=N passed to Setup.bat."/>
							</Grid>
							<Grid Margin="0,8,0,0">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<TextBox Grid.Column="0" Text="{Binding Settings.GitDependencyCachePath, UpdateSourceTrigger=PropertyChanged}"
										 hc:InfoElement.Placeholder="Cache path (leave empty for default)"
										 Style="{StaticResource TextBoxExtend}"
										 Margin="0,0,8,0"
										 IsEnabled="{Binding Settings.GitDependencyEnableCache}"
										 ToolTip="Where Setup.bat caches downloaded blobs. Default is %USERPROFILE%\Documents\UnrealBinaryBuilder\GitCache."/>
								<Button Grid.Column="1" Content="Browse" Command="{Binding BrowseGitCachePathCommand}" Width="100"
										IsEnabled="{Binding Settings.GitDependencyEnableCache}"/>
							</Grid>
							<Grid Margin="0,8,0,0">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<TextBlock Text="Cache days" VerticalAlignment="Center" Margin="0,0,6,0"
										   ToolTip="How long a cached blob is considered fresh before it's evicted on the next run."/>
								<TextBox Grid.Column="1" Text="{Binding Settings.GitDependencyCacheDays}" Margin="0,0,12,0"
										 IsEnabled="{Binding Settings.GitDependencyEnableCache}"/>
								<TextBlock Grid.Column="2" Text="Multiplier" VerticalAlignment="Center" Margin="0,0,6,0"
										   ToolTip="Cache size budget as a multiplier of the current download. 2× means the cache may grow to twice the size of one engine sync."/>
								<TextBox Grid.Column="3" Text="{Binding Settings.GitDependencyCacheMultiplier}"
										 IsEnabled="{Binding Settings.GitDependencyEnableCache}"/>
							</Grid>
						</StackPanel>
					</GroupBox>

					<GroupBox Header="Compile options" Margin="0,12,0,0">
						<StackPanel Margin="6">
							<TextBlock Style="{StaticResource SectionHelp}"
									   Text="BuildGraph -set:&lt;flag&gt;=true overrides that control what the engine compile produces."/>
							<WrapPanel>
								<CheckBox Content="Build DDC" IsChecked="{Binding Settings.WithDdc}" Margin="0,4,18,4"
										  ToolTip="Builds a stand-alone Derived Data Cache so the editor doesn't pay shader / asset cook time on first launch. Adds 30–90 min to the build."/>
								<CheckBox Content="Host DDC only" IsChecked="{Binding Settings.HostPlatformDdcOnly}" Margin="0,4,18,4"
										  IsEnabled="{Binding Settings.WithDdc}"
										  ToolTip="Only build DDC for the host platform (Win64). Skips DDC generation for every other enabled platform — saves significant time on multi-platform builds."/>
								<CheckBox Content="Sign executables" IsChecked="{Binding Settings.SignExecutables}" Margin="0,4,18,4"
										  ToolTip="Code-sign the built executables on platforms that support it. Requires a configured signing identity; off by default."/>
								<CheckBox Content="Symbol store" IsChecked="{Binding Settings.EnableSymStore}" Margin="0,4,18,4"
										  ToolTip="Embed source-server info in PDBs so debuggers can fetch the matching source. Set the SymStorePath env var to point at your symbol server."/>
								<CheckBox Content="Full debug info" IsChecked="{Binding Settings.WithFullDebugInfo}" Margin="0,4,18,4"
										  ToolTip="Generate full PDBs / debug symbols for every configuration (not just Development). Significantly increases build size and time. Off unless you need to debug into Shipping binaries."/>
								<CheckBox Content="Clean previous" IsChecked="{Binding Settings.CleanBuild}" Margin="0,4,18,4"
										  ToolTip="Appends -Clean to BuildGraph so it wipes intermediate state before building. Forces a fresh compile — slower but eliminates stale-cache failures."/>
								<CheckBox Content="Server target" IsChecked="{Binding Settings.WithServer}" Margin="0,4,18,4"
										  ToolTip="Build the dedicated-server target (headless game executable). Needed for multiplayer projects with a separate server build."/>
								<CheckBox Content="Client target" IsChecked="{Binding Settings.WithClient}" Margin="0,4,18,4"
										  ToolTip="Build the client-only target (no server code). Needed for projects that ship a separate client executable in addition to or instead of the standard game target."/>
								<CheckBox Content="Datasmith plugins" IsChecked="{Binding Settings.CompileDatasmithPlugins}" Margin="0,4,18,4"
										  ToolTip="Compile the Datasmith importer plugins (USD, CAD, Solidworks, Rhino, etc.). WARNING: enabling this can trigger a 'Digest mismatch' failure at the 'Make Installed Build' stage on UE 5.x because UBT rewrites every UnrealEditor.modules digest mid-build. Leave off unless you actually use Datasmith."/>
							</WrapPanel>
						</StackPanel>
					</GroupBox>
				</StackPanel>

				<!-- Right column -->
				<StackPanel Grid.Column="1" Margin="8,0,0,0">

					<GroupBox Header="Target platforms">
						<StackPanel Margin="6">
							<TextBlock Style="{StaticResource SectionHelp}"
									   Text="Which platforms BuildGraph compiles. Each enabled platform adds significant time and disk space — only check what you actually need."/>
							<CheckBox Content="Host platform only" IsChecked="{Binding Settings.HostPlatformOnly}" Margin="0,4"
									  ToolTip="Build only the platform you're running on (Win64). Disables the per-platform list below."/>
							<CheckBox Content="Host platform editor only" IsChecked="{Binding Settings.HostPlatformEditorOnly}" Margin="0,4"
									  ToolTip="Build only the editor (no game/server runtimes for other platforms). Smallest possible build for engine work."/>
							<Separator Margin="0,8"/>
							<WrapPanel IsEnabled="{Binding Settings.HostPlatformOnly, Converter={StaticResource InverseBool}}">
								<CheckBox Content="Win64" IsChecked="{Binding Settings.WithWin64}" Margin="0,4,18,4"
										  ToolTip="Windows 64-bit. The standard editor + runtime target. You almost always want this on."/>
								<CheckBox Content="Win32 (UE4 only)" IsChecked="{Binding Settings.WithWin32}" Margin="0,4,18,4"
										  ToolTip="Legacy Windows 32-bit runtime. UE5 dropped this — flag is silently ignored on UE5 builds."/>
								<CheckBox Content="Mac" IsChecked="{Binding Settings.WithMac}" Margin="0,4,18,4"
										  ToolTip="Mac runtime. The actual Mac compile happens later from a Mac; this just bundles cross-tooling."/>
								<CheckBox Content="Linux" IsChecked="{Binding Settings.WithLinux}" Margin="0,4,18,4"
										  ToolTip="Linux x64 runtime. Requires the Linux cross-toolchain (LINUX_MULTIARCH_ROOT) installed."/>
								<CheckBox Content="Linux Arm64" IsChecked="{Binding Settings.WithLinuxArm64}" Margin="0,4,18,4"
										  ToolTip="Linux ARM64 runtime (servers, Jetson). Requires the LinuxArm64 cross-toolchain. UE 4.24+."/>
								<CheckBox Content="Android" IsChecked="{Binding Settings.WithAndroid}" Margin="0,4,18,4"
										  ToolTip="Android runtime. Requires Android Studio + NDK installed and configured."/>
								<CheckBox Content="iOS" IsChecked="{Binding Settings.WithIOS}" Margin="0,4,18,4"
										  ToolTip="iOS runtime. The actual iOS compile needs a Mac; this stages cross-tooling."/>
								<CheckBox Content="tvOS" IsChecked="{Binding Settings.WithTVOS}" Margin="0,4,18,4"
										  ToolTip="tvOS runtime. Same Mac requirement as iOS."/>
								<CheckBox Content="HoloLens" IsChecked="{Binding Settings.WithHoloLens}" Margin="0,4,18,4"
										  ToolTip="Microsoft HoloLens runtime. Dropped in UE 5.3; valid for UE4 + UE5.0–5.2."/>
								<CheckBox Content="Switch" IsChecked="{Binding Settings.WithSwitch}" Margin="0,4,18,4"
										  ToolTip="Nintendo Switch runtime. Requires NDA platform extensions; only enable if you have access."/>
								<CheckBox Content="PS4" IsChecked="{Binding Settings.WithPS4}" Margin="0,4,18,4"
										  ToolTip="PlayStation 4 runtime. NDA-only platform extensions required."/>
								<CheckBox Content="PS5" IsChecked="{Binding Settings.WithPS5}" Margin="0,4,18,4"
										  ToolTip="PlayStation 5 runtime. UE5 only. NDA-only platform extensions required."/>
								<CheckBox Content="XboxOne" IsChecked="{Binding Settings.WithXboxOne}" Margin="0,4,18,4"
										  ToolTip="Xbox One runtime. NDA-only platform extensions required."/>
								<CheckBox Content="XSX" IsChecked="{Binding Settings.WithXSX}" Margin="0,4,18,4"
										  ToolTip="Xbox Series X/S runtime. UE5 only. NDA-only platform extensions required."/>
							</WrapPanel>
						</StackPanel>
					</GroupBox>

					<GroupBox Header="Custom BuildGraph script" Margin="0,12,0,0">
						<StackPanel Margin="6">
							<TextBlock Style="{StaticResource SectionHelp}"
									   Text="Override the default Engine/Build/InstalledEngineBuild.xml or pass extra flags to BuildGraph. Most users leave these empty."/>
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<TextBox Grid.Column="0" Text="{Binding Settings.CustomBuildXmlFile, UpdateSourceTrigger=PropertyChanged}"
										 hc:InfoElement.Placeholder="(Optional) Path to a custom InstalledEngineBuild.xml"
										 Style="{StaticResource TextBoxExtend}" Margin="0,0,8,0"
										 ToolTip="Replace the default BuildGraph script with one of your own. Leave empty to use Engine/Build/InstalledEngineBuild.xml."/>
								<Button Grid.Column="1" Content="Browse" Command="{Binding BrowseCustomBuildXmlCommand}" Margin="0,0,4,0" Width="80"/>
								<Button Grid.Column="2" Content="Reset" Command="{Binding ResetCustomBuildXmlCommand}" Width="80"
										ToolTip="Clear the custom path and fall back to the default script."/>
							</Grid>
							<TextBox Margin="0,8,0,0" Text="{Binding Settings.GameConfigurations}"
									 hc:InfoElement.Placeholder="Game configurations (semicolon-separated)"
									 Style="{StaticResource TextBoxExtend}"
									 ToolTip="Which build configurations to produce. Defaults to Development;Shipping. Add Debug if your team needs debug binaries."/>
							<TextBox Margin="0,8,0,0" Text="{Binding Settings.CustomBuildOptions}"
									 hc:InfoElement.Placeholder="Extra command-line options (only used with a custom XML)"
									 Style="{StaticResource TextBoxExtend}"
									 ToolTip="Free-form arguments appended to BuildGraph when a custom XML is set. Ignored with the default script."/>
							<TextBox Margin="0,8,0,0" Text="{Binding Settings.AnalyticsOverride}"
									 hc:InfoElement.Placeholder="Analytics override identifier (optional)"
									 Style="{StaticResource TextBoxExtend}"
									 ToolTip="Sets -set:AnalyticsTypeOverride=&lt;value&gt; on the BuildGraph call. Empty means default. Most users can ignore this."/>
						</StackPanel>
					</GroupBox>

					<GroupBox Header="Zip output" Margin="0,12,0,0">
						<StackPanel Margin="6">
							<TextBlock Style="{StaticResource SectionHelp}"
									   Text="Optionally pack the installed engine output (LocalBuilds\Engine\Windows) into a single zip for distribution."/>
							<CheckBox Content="Zip the installed build after compile" IsChecked="{Binding Settings.ZipEngineBuild}" Margin="0,2"
									  ToolTip="When the BuildGraph stage succeeds, package LocalBuilds/Engine/Windows into one zip using the filters below."/>
							<Grid Margin="0,8,0,0" IsEnabled="{Binding Settings.ZipEngineBuild}">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<TextBox Grid.Column="0" Text="{Binding Settings.ZipEnginePath, UpdateSourceTrigger=PropertyChanged}"
										 hc:InfoElement.Placeholder="e.g. C:\Builds\UnrealEngine_5.7.4.zip"
										 Style="{StaticResource TextBoxExtend}" Margin="0,0,8,0"
										 ToolTip="Path of the zip file to write. Parent folder is created if missing. Pick somewhere with plenty of free disk."/>
								<Button Grid.Column="1" Content="Browse" Command="{Binding BrowseZipPathCommand}" Width="100"/>
							</Grid>
							<TextBlock Style="{StaticResource SectionHelp}" Margin="0,12,0,4"
									   Text="What to include — uncheck to make the zip smaller. Engine binaries are always included; these toggles control optional folders/file types."/>
							<WrapPanel IsEnabled="{Binding Settings.ZipEngineBuild}">
								<CheckBox Content="PDB" IsChecked="{Binding Settings.ZipIncludePdb}" Margin="0,4,16,4"
										  ToolTip=".pdb debug symbols (~20–40 GB on a full build). Drop to shrink the zip; keep if recipients need to read crash dumps or attach a debugger."/>
								<CheckBox Content="Debug" IsChecked="{Binding Settings.ZipIncludeDebug}" Margin="0,4,16,4"
										  ToolTip=".debug files (Linux / Mac symbol equivalent). Drop unless you need to debug into Linux or Mac binaries."/>
								<CheckBox Content="Source" IsChecked="{Binding Settings.ZipIncludeSource}" Margin="0,4,16,4"
										  ToolTip="Engine/Source/* — engine C++ source. Several GB. Drop for binary distributions; keep if recipients need to recompile or read engine code."/>
								<CheckBox Content="Documentation" IsChecked="{Binding Settings.ZipIncludeDocumentation}" Margin="0,4,16,4"
										  ToolTip="Engine/Documentation. Almost always safe to drop — Epic's online docs are more current."/>
								<CheckBox Content="Extras" IsChecked="{Binding Settings.ZipIncludeExtras}" Margin="0,4,16,4"
										  ToolTip="Engine/Extras (Maya plugins, VS integration, etc.). Engine/Extras/Redist (VC++/DirectX runtime installers) is always included regardless of this toggle."/>
								<CheckBox Content="Feature Packs" IsChecked="{Binding Settings.ZipIncludeFeaturePacks}" Margin="0,4,16,4"
										  ToolTip="FeaturePacks/* — starter content packs (FirstPerson, ThirdPerson, etc.). Several hundred MB. Drop unless you need them; they can be re-added later."/>
								<CheckBox Content="Samples" IsChecked="{Binding Settings.ZipIncludeSamples}" Margin="0,4,16,4"
										  ToolTip="Samples/* — sample projects shipped with the engine. Often several GB; drop unless your team specifically uses them."/>
								<CheckBox Content="Templates" IsChecked="{Binding Settings.ZipIncludeTemplates}" Margin="0,4,16,4"
										  ToolTip="Templates/* — &quot;new project&quot; templates the editor uses for File &gt; New Project. Keep if recipients create new projects via the editor."/>
								<CheckBox Content="Fast (lower compression)" IsChecked="{Binding Settings.ZipFastCompression}" Margin="0,4,16,4"
										  ToolTip="Use Fastest compression — much faster zip stage but larger file. Off uses SmallestSize, which is slow but produces the tightest archive."/>
							</WrapPanel>
							<Grid Margin="0,8,0,0" Visibility="{Binding ZipProgress.IsActive, Converter={StaticResource BoolToVisibility}}">
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="Auto"/>
								</Grid.RowDefinitions>
								<TextBlock Grid.Row="0" Text="{Binding ZipProgress.Stats}"/>
								<TextBlock Grid.Row="1" Text="{Binding ZipProgress.CurrentFile}" Margin="0,4,0,4" Opacity="0.85"/>
								<ProgressBar Grid.Row="2" Style="{DynamicResource ProgressBarInfoStripe}"
											 Value="{Binding ZipProgress.OverallProgress}" Maximum="{Binding ZipProgress.OverallProgressMax}"/>
							</Grid>
						</StackPanel>
					</GroupBox>

					<GroupBox Header="After build" Margin="0,12,0,0">
						<StackPanel Margin="6">
							<TextBlock Style="{StaticResource SectionHelp}"
									   Text="Optional auto-shutdown — handy for overnight builds when you don't want to leave the machine running."/>
							<WrapPanel>
								<CheckBox Content="Shut down PC" IsChecked="{Binding Settings.ShutdownPc}" Margin="0,4,16,4"
										  ToolTip="Calls 'shutdown /s /t 30' once the build (and any zip) finishes. 30-second grace period in case you change your mind."/>
								<CheckBox Content="Only if successful" IsChecked="{Binding Settings.ShutdownIfBuildSuccessOnly}" Margin="0,4,16,4"
										  IsEnabled="{Binding Settings.ShutdownPc}"
										  ToolTip="Only shut down on a clean build. On failure the machine stays up so you can read the log."/>
							</WrapPanel>
						</StackPanel>
					</GroupBox>
				</StackPanel>
			</Grid>
		</ScrollViewer>

		<!-- Build button row -->
		<Border Grid.Row="2" Background="{DynamicResource RegionBrush}" CornerRadius="6" Padding="12" Margin="0,12,0,0"
				BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<TextBlock VerticalAlignment="Center" Text="Sync your engine source first, then click Build. Live progress shows in the Output tab and the bar below." Opacity="0.7"/>
				<Button Grid.Column="1" Content="Cancel"
						Command="{Binding CancelCommand}"
						IsEnabled="{Binding Status.IsBusy}"
						Width="100" Margin="0,0,8,0"
						ToolTip="Stop the running stage and clean up. Cancellation is cooperative — the current command is killed; in-flight downloads or compiles may take a few seconds to wind down."/>
				<Button Grid.Column="2" Content="Build Unreal Engine"
						Command="{Binding BuildCommand}"
						IsEnabled="{Binding CanBuild}"
						Style="{StaticResource ButtonPrimary}"
						Width="220"
						ToolTip="Run the pipeline stages you've enabled above, end-to-end. This usually takes hours."/>
			</Grid>
		</Border>
	</Grid>
</UserControl>
